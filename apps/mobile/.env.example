# LAN IP of your PC (required for iPhone/Android on same Wi-Fi). Run: ipconfig
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.10

# Local API (monolith or Docker gateway on :3000)
EXPO_PUBLIC_API_URL=http://192.168.1.10:3000

# Railway staging API (datespot-staging project)
# EXPO_PUBLIC_API_URL=https://datespot-staging.up.railway.app

# EAS preview/staging builds use eas.json env — no .env needed on build servers.
# For local dev against staging, uncomment the Railway URL above.

# Required per PRD 9.2 (Google Maps Platform). Create a key at:
# https://console.cloud.google.com/google/maps-apis
# Enable Maps SDK for Android/iOS. Target: iOS 15+, Android 10+ (see app.json).
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
