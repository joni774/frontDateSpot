{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_API_URL": "https://datespot-server-production.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_API_URL": "https://datespot-server-production.up.railway.app"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "staging": {
      "extends": "preview",
      "channel": "staging"
    },
    "production": {
      "distribution": "store",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_URL": "https://datespot-server-production-ecb2.up.railway.app"
      },
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
