{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "node scripts/start-expo.mjs --tunnel",
    "dev:lan": "node scripts/start-expo.mjs --lan",
    "dev:tunnel": "node scripts/start-expo.mjs --tunnel",
    "dev:web": "expo start --web --port 8081",
    "print-qr": "node scripts/print-expo-qr.mjs --lan",
    "print-qr:tunnel": "node scripts/print-expo-qr.mjs --tunnel --wait",
    "print-qr:lan": "node scripts/print-expo-qr.mjs --lan",
    "save-qr": "node scripts/save-qr-html.mjs",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "eas:init": "eas init",
    "build:staging:android": "eas build --profile preview --platform android --non-interactive",
    "build:staging:ios": "eas build --profile preview --platform ios --non-interactive",
    "build:production:android": "eas build --profile production --platform android --non-interactive",
    "build:production:ios": "eas build --profile production --platform ios --non-interactive"
  },
  "dependencies": {
    "@datespot/api-client": "workspace:*",
    "@datespot/shared-types": "workspace:*",
    "@datespot/ui": "workspace:*",
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^3.9.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.59.0",
    "axios": "^1.7.7",
    "expo": "~54.0.24",
    "expo-asset": "~12.0.12",
    "expo-constants": "~18.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "^57.0.3",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "i18next": "^23.16.4",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.53.1",
    "react-i18next": "^15.1.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
